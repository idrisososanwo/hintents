#![no_std]

use soroban_sdk::{contract, contractimpl, contracttype, Address, Env};

#[contracttype]
#[derive(Clone)]
pub enum DataKey {
    Nonce,
}

#[contract]
pub struct AuthTestContract;

#[contractimpl]
impl AuthTestContract {
    pub fn init(env: Env) {
        if !env.storage().instance().has(&DataKey::Nonce) {
            env.storage().instance().set(&DataKey::Nonce, &0_u64);
        }
    }

    pub fn authorize_step(env: Env, invoker: Address, secondary: Address) -> u64 {
        invoker.require_auth();
        secondary.require_auth();

        let nonce = env
            .storage()
            .instance()
            .get::<DataKey, u64>(&DataKey::Nonce)
            .unwrap_or(0);

        let next = nonce + 1;
        env.storage().instance().set(&DataKey::Nonce, &next);
        next
    }

    pub fn nonce(env: Env) -> u64 {
        env.storage()
            .instance()
            .get::<DataKey, u64>(&DataKey::Nonce)
            .unwrap_or(0)
    }
}